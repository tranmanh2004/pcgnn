    "## Cell 3 - Map Generation (3×3 Context theo paper PCGNN)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "6f4c1c45",
   "metadata": {
    "execution": {
     "iopub.execute_input": "2026-04-19T15:31:56.411642Z",
