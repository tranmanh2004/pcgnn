     "shell.execute_reply": "2026-04-19T15:31:56.442623Z",
     "shell.execute_reply.started": "2026-04-19T15:31:56.411612Z"
    },
    "papermill": {
     "duration": 0.026525,
     "end_time": "2026-04-16T17:35:28.572007+00:00",
     "exception": false,
     "start_time": "2026-04-16T17:35:28.545482+00:00",
